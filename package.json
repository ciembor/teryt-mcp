{
  "name": "teryt-mcp",
  "version": "0.1.4",
  "private": false,
  "description": "MCP server for the official Polish TERYT registry.",
  "type": "module",
  "packageManager": "pnpm@10.12.1",
  "bin": {
    "teryt-mcp": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/main.ts src/cli.ts src/postinstall.ts --format esm --dts --clean",
    "postinstall": "node dist/postinstall.js",
    "prepare": "git rev-parse --is-inside-work-tree >/dev/null 2>&1 && git config core.hooksPath .githooks || true",
    "quality": "mcp-craftman quality",
    "test": "vitest run"
  },
  "dependencies": {
    "@mcp-craftman/core": "^0.2.0",
    "@mcp-craftman/node": "^0.2.0",
    "fflate": "^0.8.3",
    "sql.js": "^1.14.1"
  },
  "devDependencies": {
    "@mcp-craftman/cli": "^0.2.0",
    "@types/node": "^24.0.3",
    "@types/sql.js": "^1.4.11",
    "@vitest/coverage-v8": "^3.2.4",
    "dependency-cruiser": "^13.1.5",
    "eslint": "^9.29.0",
    "eslint-plugin-sonarjs": "^3.0.3",
    "knip": "^5.61.3",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.34.1",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20.19.0"
  }
}
